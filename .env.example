# Desk pipeline (Edge health + publish): copy scripts/supabase/env.supabase.local.example → .env.supabase.local (gitignored)

VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_GNEWS_API_KEY="your-gnews-api-key"
VITE_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
VITE_SENTRY_DSN=""

# Optional: The Reset Room — $15/mo (live session: The Briefing Room). Must match Supabase STRIPE_BRIEFING_ROOM_PRICE_ID for checkout + check-subscription (subscriber chip)
# VITE_STRIPE_BRIEFING_ROOM_PRICE_ID="price_xxxxxxxx"
# Founding Supporters: only same calendar month/year (UTC) for /join, /hire, new accounts, or early_access_signups
# VITE_BRIEFING_ROOM_JOINERS_ONLY="true"
# VITE_BRIEFING_ROOM_FOUNDING_YEAR="2026"
# VITE_BRIEFING_ROOM_FOUNDING_MONTH="4"
# Supabase create-checkout + optional check-subscription: BRIEFING_ROOM_JOINERS_ONLY ("false" = anyone), BRIEFING_ROOM_FOUNDING_YEAR, BRIEFING_ROOM_FOUNDING_MONTH (default April, current UTC year)

# Sales / public launch: set to "true" on Production to hide unfinished product links from footer & menus and
# soft-gate /jobs for signed-out visitors. Test: VITE_PUBLIC_MARKETING_LAUNCH=true npm run build && npm run preview
# VITE_PUBLIC_MARKETING_LAUNCH="true"
