# Copy to repo root as `.env.supabase.local` (gitignored).
# Used by: ./scripts/supabase/deploy.sh, ./scripts/supabase/health-check.sh
#
# Generate a strong secret (e.g. openssl rand -base64 32) and use the SAME value
# locally and on Supabase Edge (run ./scripts/supabase/push-edge-secrets.sh once).

WDIWF_DESK_PUBLISH_SECRET="paste-a-long-random-secret-here"

# Optional: override if you use a custom API URL (otherwise derived from supabase/config.toml)
# SUPABASE_URL="https://aeulesuqxcnaonlxcjcm.supabase.co"
